NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Auth mode: auto (dev fallback), jwt, or dev
AUTH_MODE=auto
JWT_SECRET=replace_me_if_jwt
JWT_ISSUER=
JWT_AUDIENCE=
FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json
# Alternative for deployments where file mounts are hard:
# Plain JSON or base64-encoded JSON service account payload.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Premium
TRIAL_DURATION_HOURS=24
REVENUECAT_WEBHOOK_SECRET=replace_me
PREMIUM_ADMIN_SECRET=replace_me

# MySQL Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=replace_me
DB_PASSWORD=replace_me
DB_NAME=replace_me

# Bunny CDN (Slim30 key names)
CDN_STORAGE_ZONE=replace_me
CDN_ACCESS_KEY=replace_me
CDN_HOSTNAME=replace_me

# Optional DayFlow-compatible aliases (fallback)
CDN_USERNAME=replace_me
CDN_PASSWORD=replace_me


DEFAULT_DEV_USER_ID=1

# OneSignal
ONESIGNAL_APP_ID=replace_me
ONESIGNAL_REST_API_KEY=replace_me
